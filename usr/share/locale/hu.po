msgid "Backups"
msgstr "Biztonsági mentések"

msgid "Create backup now"
msgstr "Biztonsági mentés készítése most"

msgid "Snapshot current dconf settings"
msgstr "Pillanatkép a jelenlegi dconf beállításokról"

msgid "No backups yet"
msgstr "Még nincs biztonsági mentés"

msgid "A backup is created automatically every time you apply a layout."
msgstr ""
"Minden alkalommal, amikor alkalmazol egy elrendezést, automatikusan készül "
"egy biztonsági mentés."

msgid "Latest"
msgstr "Legfrissebb"

msgid "Restore this backup"
msgstr "Biztonsági mentés visszaállítása"

