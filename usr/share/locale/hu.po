msgstr "Biztonsági mentés törlése"

msgid "Backup created"
msgstr "Biztonsági mentés elkészült"

msgid "Backup failed"
msgstr "Biztonsági mentés sikertelen"

msgid "Restore this backup?"
msgstr "Visszaállítod ezt a biztonsági mentést?"

#, python-brace-format
msgid ""
"All current dconf settings will be overwritten with the snapshot from {ts}."
msgstr "A megjelölt elrendezések tartalmazzák a mentett testreszabásokat — kattintson a folytatáshoz vagy az eredeti alkalmazásához.""Minden jelenlegi dconf beállítás felülíródik a {ts} időpontban készült "
"pillanatképpel."

msgid "Cancel"
msgstr "Mégse"

msgid "Restore"
msgstr "Visszaállítás"

msgid "Backup restored"
msgstr "Biztonsági mentés visszaállítva"

msgid "Restore failed"
msgstr "Visszaállítás sikertelen"

msgid "Delete this backup?"
msgstr "Törli ezt a biztonsági mentést?"

