msgid "Backups"
msgstr "Архиви"

msgid "Create backup now"
msgstr "Създай архив сега"

msgid "Snapshot current dconf settings"
msgstr "Заснеми текущите dconf настройки"

msgid "No backups yet"
msgstr "Все още няма архиви"

msgid "A backup is created automatically every time you apply a layout."
msgstr "Архив се създава автоматично всеки път, когато приложите оформление."

msgid "Latest"
msgstr "Последен"

msgid "Restore this backup"
msgstr "Възстанови този архив"

msgid "Delete this backup"
msgstr "Изтрий този архив"

msgid "Backup created"
msgstr "Архивът е създаден"

msgid "Backup failed"
msgstr "Архивирането не бе успешно"

msgid "Restore this backup?"
msgstr "Да възстановя ли този архив?"

#, python-brace-format
msgid ""
"All current dconf settings will be overwritten with the snapshot from {ts}."
msgstr "Отбелязаните оформления съдържат запазените ви персонализации — щракнете, за да ги възобновите или да приложите оригинала.""Всички текущи dconf настройки ще бъдат презаписани със снимката от {ts}."

msgid "Cancel"
msgstr "Отказ"

msgid "Restore"
msgstr "Възстанови"

msgid "Backup restored"
msgstr "Архивът е възстановен"

msgid "Restore failed"
msgstr "Възстановяването не бе успешно"

msgid "Delete this backup?"
msgstr "Да изтрием ли тази резервна копие?"

msgid "Delete"
msgstr "Изтрий"

msgid "Backup deleted"
msgstr "Резервната копие е изтрита"

msgid "Delete failed"
msgstr "Неуспешно изтриване"

msgid "Layout Switcher"
msgstr "Layout Switcher"

msgid "Show Sidebar"
msgstr "Покажи страничната лента"

msgid "Layouts"
msgstr "Оформления"

msgid "Menu"
msgstr "Меню"

msgid "Main menu"
msgstr "Основно меню"

msgid "Backups…"
msgstr "Резервни копия…"

msgid "About"
msgstr "Относно"

msgid "Welcome! Choose a desktop layout below to get started."
msgstr ""
"Добре дошли! Изберете оформление на работния плот по-долу, за да започнете."

msgid "Got it"
msgstr "Разбрах"

msgid "Fonts"
msgstr "Шрифтове"

msgid "Themes"
msgstr "Теми"

msgid "Effects"
msgstr "Ефекти"

msgid "Extensions"
msgstr "Разширения"

msgid "Community Layout Switcher"
msgstr "Community Layout Switcher"

msgid "Layouts, effects and themes for your GNOME desktop."
msgstr "Оформления, ефекти и теми за вашия GNOME десктоп."

msgid "Filter themes…"
msgstr "Филтриране на теми…"

msgid "Icons"
msgstr "Икони"

msgid "No themes found"
msgstr "Не са намерени теми"

msgid "Install themes to ~/.themes or /usr/share/themes"
msgstr "Инсталирайте теми в ~/.themes или /usr/share/themes"

msgid "themes available"
msgstr "налични теми"

msgid "theme"
msgstr "тема"

msgid "Active"
msgstr "Активно"

msgid "Error"
msgstr "Грешка"

msgid "User Themes required"
msgstr "Необходими са потребителски теми"

msgid "Install and enable the User Themes extension to apply shell themes."
msgstr ""
"Инсталирайте и активирайте разширението User Themes, за да приложите теми за "
"обвивката."

msgid "Open Extensions Page"
msgstr "Отворете страницата с разширения"

msgid "Visual effects for your GNOME desktop"
msgstr "Визуални ефекти за вашия GNOME десктоп"

msgid "System extension"
msgstr "Системно разширение"

msgid "enabled"
msgstr "активирано"

msgid "disabled"
msgstr "деактивирано"

msgid "Not installed"
msgstr "Не е инсталирано"

#, python-brace-format
msgid "by {author}"
msgstr "от {author}"

msgid "On"
msgstr "Включено"

msgid "Off"
msgstr "Изключено"

msgid "Toggle"
msgstr "Превключи"

msgid "Remove"
msgstr "Премахни"

msgid "Settings"
msgstr "Настройки"

msgid "Install"
msgstr "Инсталирай"

msgid "View on GNOME Extensions"
msgstr "Преглед в GNOME Extensions"

msgid "Install effect?"
msgstr "Инсталиране на ефекта?"

msgid "Will try to install automatically."
msgstr "Ще се опита да инсталира автоматично."

msgid "Installing…"
msgstr "Инсталиране…"

msgid "installed"
msgstr "инсталиран"

msgid "Install failed"
msgstr "Инсталацията неуспешна"

msgid "System extension — cannot remove"
msgstr "Системно разширение — не може да бъде премахнато"

msgid "Remove effect?"
msgstr "Премахване на ефекта?"

msgid "This cannot be undone."
msgstr "Това не може да бъде отменено."

msgid "removed"
msgstr "премахнат"

msgid "Remove failed"
msgstr "Премахването неуспешно"

msgid "System fonts"
msgstr "Системни шрифтове"

msgid "Fonts used by the GNOME interface"
msgstr "Шрифтове, използвани от GNOME интерфейса"

msgid "Interface"
msgstr "Интерфейс"

msgid "Document"
msgstr "Документ"

msgid "Monospace"
msgstr "Моноширинен"

msgid "Window titles (legacy)"
msgstr "Заглавия на прозорци (стари)"

msgid "(not set)"
msgstr "(не е зададено)"

msgid "Choose…"
msgstr "Избери…"

msgid "Choose font"
msgstr "Избери шрифт"

msgid "Font updated"
msgstr "Шрифтът е обновен"

msgid "Update failed"
msgstr "Обновяването не бе успешно"

msgid "Appearance"
msgstr "Външен вид"

msgid "How fonts are rendered on screen"
msgstr "Как шрифтовете се изобразяват на екрана"

msgid "Hinting"
msgstr "Подсказване"

msgid "None"
msgstr "Няма"

msgid "Slight"
msgstr "Леко"

msgid "Medium"
msgstr "Средно"

msgid "Full"
msgstr "Пълно"

msgid "Antialiasing"
msgstr "Антиалиасинг"

msgid "Grayscale"
msgstr "Градации на сивото"

msgid "Subpixel (RGBA)"
msgstr "Субпиксел (RGBA)"

msgid "Installed fonts"
msgstr "Инсталирани шрифтове"

msgid "Browse font families installed on your system"
msgstr "Преглед на шрифтове, инсталирани на вашата система"

msgid "Search fonts…"
msgstr "Търсене на шрифтове…"

msgid "Refresh font list"
msgstr "Обнови списъка с шрифтове"

msgid "Loading fonts…"
msgstr "Зареждане на шрифтове…"

msgid "No fonts match your search"
msgstr "Няма шрифтове, отговарящи на търсенето ви"

msgid "(refine search to see more)"
msgstr "(уточнете търсенето, за да видите повече)"

msgid "fonts"
msgstr "шрифтове"

msgid "The quick brown fox jumps over the lazy dog 0123"
msgstr "Ах, чудна българска земьо, полюшвай цъфтящи жита 0123"

msgid "Install more fonts"
msgstr "Инсталирай още шрифтове"

msgid "Browse Google Fonts"
msgstr "Преглед на Google Fonts"

msgid "Opens fonts.google.com in your browser"
msgstr "Отваря fonts.google.com във вашия браузър"

msgid "How to install"
msgstr "Как да инсталирате"

msgid ""
"Place .ttf/.otf files in ~/.local/share/fonts/ then run 'fc-cache -f -v' and "
"refresh this list."
msgstr ""
"Поставете .ttf/.otf файлове в ~/.local/share/fonts/, след това изпълнете 'fc-"
"cache -f -v' и обновете този списък."

msgid "Reset to system defaults"
msgstr "Върни към системните настройки по подразбиране"

msgid "Reset all font settings?"
msgstr "Да се нулират ли всички настройки на шрифтовете?"

msgid ""
"Interface, document, monospace and window-title fonts will return to system "
"defaults. Hinting and antialiasing reset too."
msgstr ""
"Шрифтовете за интерфейс, документи, моноширинни и заглавия на прозорци ще се "
"върнат към системните настройки по подразбиране. Също така ще бъдат нулирани "
"подсказките и антиалиасингът."

msgid "Reset"
msgstr "Нулиране"

msgid "Fonts reset to defaults"
msgstr "Шрифтовете са върнати към настройките по подразбиране"

msgid "Featured"
msgstr "Препоръчани"

msgid "Installed"
msgstr "Инсталирани"

msgid "Install extension?"
msgstr "Да се инсталира разширение?"

msgid "Remove extension?"
msgstr "Да се премахне разширение?"

msgid "Open GNOME Extensions"
msgstr "Отвори GNOME Extensions"

msgid "No extensions installed"
msgstr "Няма инсталирани разширения"

msgid "Enabled"
msgstr "Активирано"

msgid "Disabled"
msgstr "Деактивирано"

msgid "system"
msgstr "система"

msgid "Disable All"
msgstr "Деактивирай всички"

msgid "Enable All"
msgstr "Активирай всички"

msgid "Disable all extensions?"
msgstr "Да деактивираме всички разширения?"

msgid "All extensions will be disabled. You can re-enable them later."
msgstr ""
"Всички разширения ще бъдат деактивирани. Можете да ги активирате отново по-"
"късно."

msgid "All extensions disabled"
msgstr "Всички разширения са деактивирани"

msgid "All extensions enabled"
msgstr "Всички разширения са активирани"

msgid "Click a layout to apply"
msgstr "Кликнете върху оформление, за да го приложите"

msgid "Layout status"
msgstr "Статус на оформлението"

msgid ""
"Marked layouts contain your saved customizations — click to resume them or "
"apply the original."
msgstr "Отбелязаните оформления съдържат запазените ви персонализации — щракнете, за да ги възобновите или да приложите оригинала."

msgid "Contains your saved customizations"
msgstr "Съдържа вашите запазени персонализации"

msgid "Modified"
msgstr "Променено"

msgid "This layout is already active"
msgstr "Това оформление вече е активно"

msgid ""
"You have previously modified this layout. Resume your changes or apply the "
"original system default?"
msgstr ""
"Преди това сте променяли това оформление. Да възобновите промените си или да "
"приложите оригиналните системни настройки?"

msgid "Apply original"
msgstr "Приложи оригиналното"

msgid "Resume my changes"
msgstr "Възобнови моите промени"

msgid ""
"Apply this layout? A backup of your current configuration will be created "
"automatically."
msgstr ""
"Да приложа това оформление? Автоматично ще бъде създаден архив на текущата "
"ви конфигурация."

msgid "Apply"
msgstr "Приложи"

msgid "Applying"
msgstr "Прилагане"

msgid "Snapshot not found"
msgstr "Снимка не е намерена"

msgid "Layout file not found"
msgstr "Файлът с оформление не е намерен"

msgid "applied"
msgstr "приложено"

msgid "Undo"
msgstr "Отмяна"

msgid "Layout restored"
msgstr "Оформлението е възстановено"

msgid "Previous layout restored"
msgstr "Предишното оформление е възстановено"

msgid "Default Big Gnome layout"
msgstr "По подразбиране голямо оформление на Gnome"

msgid "Clean and contemporary desktop"
msgstr "Чист и модерен десктоп"

msgid "Centered dock-taskbar, Windows 11 / Deepin / Pop!_OS style"
msgstr "Центрирана лента-док, стил Windows 11 / Deepin / Pop!_OS"

msgid "Unity-style layout with left dock and top bar"
msgstr "Оформление в стил Unity с ляв док и горна лента"

msgid "Traditional desktop with taskbar and system tray"
msgstr "Традиционен десктоп с лента на задачите и системен трей"

msgid "Near-vanilla GNOME with minimal distro tweaks"
msgstr "Почти чист GNOME с минимални дистро настройки"
