msgid "Backups"
msgstr "גיבויים"

msgid "Create backup now"
msgstr "צור גיבוי עכשיו"

msgid "Snapshot current dconf settings"
msgstr "צלם מצב נוכחי של הגדרות dconf"

msgid "No backups yet"
msgstr "עדיין אין גיבויים"

