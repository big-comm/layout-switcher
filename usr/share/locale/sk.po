msgid ""
"Place .ttf/.otf files in ~/.local/share/fonts/ then run 'fc-cache -f -v' and "
"refresh this list."
msgstr ""
"Umiestnite súbory .ttf/.otf do ~/.local/share/fonts/, potom spustite 'fc-"
"cache -f -v' a obnovte tento zoznam."

