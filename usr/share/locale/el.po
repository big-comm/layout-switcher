msgid "Backups"
msgstr "Αντίγραφα ασφαλείας"

msgid "Create backup now"
msgstr "Δημιουργία αντιγράφου ασφαλείας τώρα"

msgid "Snapshot current dconf settings"
msgstr "Λήψη στιγμιότυπου τρεχουσών ρυθμίσεων dconf"

msgid "No backups yet"
msgstr "Δεν υπάρχουν αντίγραφα ασφαλείας ακόμα"

msgid "A backup is created automatically every time you apply a layout."
msgstr ""
"Ένα αντίγραφο ασφαλείας δημιουργείται αυτόματα κάθε φορά που εφαρμόζετε ένα "
"layout."

msgid "Latest"
msgstr "Τελευταίο"

msgid "Restore this backup"
msgstr "Επαναφορά αυτού του αντιγράφου ασφαλείας"

msgid "Delete this backup"
msgstr "Διαγραφή αυτού του αντιγράφου ασφαλείας"

msgid "Backup created"
msgstr "Το αντίγραφο ασφαλείας δημιουργήθηκε"

msgid "Backup failed"
msgstr "Η δημιουργία αντιγράφου ασφαλείας απέτυχε"

msgid "Restore this backup?"
msgstr "Να επαναφερθεί αυτό το αντίγραφο ασφαλείας;"

#, python-brace-format
msgid ""
"All current dconf settings will be overwritten with the snapshot from {ts}."
msgstr "Οι επισημασμένες διατάξεις περιέχουν τις αποθηκευμένες προσαρμογές σας — κάντε κλικ για να τις συνεχίσετε ή να εφαρμόσετε την αρχική.""Όλες οι τρέχουσες ρυθμίσεις dconf θα αντικατασταθούν με το στιγμιότυπο από "
"{ts}."

msgid "Cancel"
msgstr "Ακύρωση"

msgid "Restore"
msgstr "Επαναφορά"

msgid "Backup restored"
msgstr "Το αντίγραφο ασφαλείας επαναφέρθηκε"

msgid "Restore failed"
msgstr "Η επαναφορά απέτυχε"

msgid "Delete this backup?"
msgstr "Να διαγραφεί αυτό το αντίγραφο ασφαλείας;"

msgid "Delete"
msgstr "Διαγραφή"

msgid "Backup deleted"
msgstr "Το αντίγραφο ασφαλείας διαγράφηκε"

msgid "Delete failed"
msgstr "Η διαγραφή απέτυχε"

msgid "Layout Switcher"
msgstr "Layout Switcher"

msgid "Show Sidebar"
msgstr "Εμφάνιση πλαϊνής στήλης"

msgid "Layouts"
msgstr "Διατάξεις"

msgid "Menu"
msgstr "Μενού"

msgid "Main menu"
msgstr "Κύριο μενού"

msgid "Backups…"
msgstr "Αντίγραφα ασφαλείας…"

msgid "About"
msgstr "Σχετικά"

msgid "Welcome! Choose a desktop layout below to get started."
msgstr ""
"Καλώς ήρθατε! Επιλέξτε μια διάταξη επιφάνειας εργασίας παρακάτω για να "
"ξεκινήσετε.|NL|"

msgid "Got it"
msgstr "Κατάλαβα"

msgid "Fonts"
msgstr "Γραμματοσειρές"

msgid "Themes"
msgstr "Θέματα"

msgid "Effects"
msgstr "Εφέ"

msgid "Extensions"
msgstr "Επεκτάσεις"

msgid "Community Layout Switcher"
msgstr "Κοινότητα Layout Switcher"

msgid "Layouts, effects and themes for your GNOME desktop."
msgstr "Διατάξεις, εφέ και θέματα για την επιφάνεια εργασίας GNOME σας."

msgid "Filter themes…"
msgstr "Φιλτράρισμα θεμάτων…"

msgid "Icons"
msgstr "Εικονίδια"

msgid "No themes found"
msgstr "Δεν βρέθηκαν θέματα"

msgid "Install themes to ~/.themes or /usr/share/themes"
msgstr "Εγκαταστήστε θέματα στο ~/.themes ή /usr/share/themes"

msgid "themes available"
msgstr "διαθέσιμα θέματα"

msgid "theme"
msgstr "θέμα"

msgid "Active"
msgstr "Ενεργό"

msgid "Error"
msgstr "Σφάλμα"

msgid "User Themes required"
msgstr "Απαιτούνται User Themes"

msgid "Install and enable the User Themes extension to apply shell themes."
msgstr ""
"Εγκαταστήστε και ενεργοποιήστε την επέκταση User Themes για να εφαρμόσετε "
"θέματα κελύφους."

msgid "Open Extensions Page"
msgstr "Άνοιγμα σελίδας Επεκτάσεων"

msgid "Visual effects for your GNOME desktop"
msgstr "Οπτικά εφέ για την επιφάνεια εργασίας GNOME σας"

msgid "System extension"
msgstr "Επέκταση συστήματος"

msgid "enabled"
msgstr "ενεργοποιημένο"

msgid "disabled"
msgstr "απενεργοποιημένο"

msgid "Not installed"
msgstr "Δεν είναι εγκατεστημένο"

#, python-brace-format
msgid "by {author}"
msgstr "από {author}"

msgid "On"
msgstr "Ενεργό"

msgid "Off"
msgstr "Ανενεργό"

msgid "Toggle"
msgstr "Εναλλαγή"

msgid "Remove"
msgstr "Αφαίρεση"

msgid "Settings"
msgstr "Ρυθμίσεις"

msgid "Install"
msgstr "Εγκατάσταση"

msgid "View on GNOME Extensions"
msgstr "Προβολή στο GNOME Extensions"

msgid "Install effect?"
msgstr "Εγκατάσταση εφέ;"

msgid "Will try to install automatically."
msgstr "Θα προσπαθήσει να εγκατασταθεί αυτόματα."

msgid "Installing…"
msgstr "Εγκατάσταση…"

msgid "installed"
msgstr "εγκαταστάθηκε"

msgid "Install failed"
msgstr "Η εγκατάσταση απέτυχε"

msgid "System extension — cannot remove"
msgstr "Επέκταση συστήματος — δεν μπορεί να αφαιρεθεί"

msgid "Remove effect?"
msgstr "Αφαίρεση εφέ;"

msgid "This cannot be undone."
msgstr "Αυτό δεν μπορεί να αναιρεθεί."

msgid "removed"
msgstr "αφαιρέθηκε"

msgid "Remove failed"
msgstr "Η αφαίρεση απέτυχε"

msgid "System fonts"
msgstr "Γραμματοσειρές συστήματος"

msgid "Fonts used by the GNOME interface"
msgstr "Γραμματοσειρές που χρησιμοποιούνται από το περιβάλλον GNOME"

msgid "Interface"
msgstr "Περιβάλλον"

msgid "Document"
msgstr "Έγγραφο"

msgid "Monospace"
msgstr "Μονοδιάστατη (Monospace)"

msgid "Window titles (legacy)"
msgstr "Τίτλοι παραθύρων (παλαιά έκδοση)"

msgid "(not set)"
msgstr "(δεν έχει οριστεί)"

msgid "Choose…"
msgstr "Επιλογή…"

msgid "Choose font"
msgstr "Επιλογή γραμματοσειράς"

msgid "Font updated"
msgstr "Η γραμματοσειρά ενημερώθηκε"

msgid "Update failed"
msgstr "Η ενημέρωση απέτυχε"

msgid "Appearance"
msgstr "Εμφάνιση"

msgid "How fonts are rendered on screen"
msgstr "Πώς αποδίδονται οι γραμματοσειρές στην οθόνη"

msgid "Hinting"
msgstr "Υπόδειξη"

msgid "None"
msgstr "Καμία"

msgid "Slight"
msgstr "Ελαφριά"

msgid "Medium"
msgstr "Μέτρια"

msgid "Full"
msgstr "Πλήρης"

msgid "Antialiasing"
msgstr "Αντιαλίασινγκ"

msgid "Grayscale"
msgstr "Αποχρώσεις του γκρι"

msgid "Subpixel (RGBA)"
msgstr "Υποπίξελ (RGBA)"

msgid "Installed fonts"
msgstr "Εγκατεστημένες γραμματοσειρές"

msgid "Browse font families installed on your system"
msgstr ""
"Περιηγηθείτε στις οικογένειες γραμματοσειρών που είναι εγκατεστημένες στο "
"σύστημά σας"

msgid "Search fonts…"
msgstr "Αναζήτηση γραμματοσειρών…"

msgid "Refresh font list"
msgstr "Ανανέωση λίστας γραμματοσειρών"

msgid "Loading fonts…"
msgstr "Φόρτωση γραμματοσειρών…"

msgid "No fonts match your search"
msgstr "Καμία γραμματοσειρά δεν ταιριάζει με την αναζήτησή σας"

msgid "(refine search to see more)"
msgstr "(συμπληρώστε την αναζήτηση για να δείτε περισσότερα)"

msgid "fonts"
msgstr "γραμματοσειρές"

msgid "The quick brown fox jumps over the lazy dog 0123"
msgstr "Θέλει αρετή και τόλμη η ελευθερία 0123"

msgid "Install more fonts"
msgstr "Εγκατάσταση περισσότερων γραμματοσειρών"

msgid "Browse Google Fonts"
msgstr "Περιήγηση στο Google Fonts"

msgid "Opens fonts.google.com in your browser"
msgstr "Ανοίγει το fonts.google.com στον περιηγητή σας"

msgid "How to install"
msgstr "Πώς να εγκαταστήσετε"

msgid ""
"Place .ttf/.otf files in ~/.local/share/fonts/ then run 'fc-cache -f -v' and "
"refresh this list."
msgstr ""
"Τοποθετήστε αρχεία .ttf/.otf στο ~/.local/share/fonts/ και στη συνέχεια "
"εκτελέστε 'fc-cache -f -v' και ανανεώστε αυτή τη λίστα."

msgid "Reset to system defaults"
msgstr "Επαναφορά στις προεπιλογές συστήματος"

msgid "Reset all font settings?"
msgstr "Να επαναφερθούν όλες οι ρυθμίσεις γραμματοσειράς;"

msgid ""
"Interface, document, monospace and window-title fonts will return to system "
"defaults. Hinting and antialiasing reset too."
msgstr ""
"Οι γραμματοσειρές διεπαφής, εγγράφου, μονοδιάστατης και τίτλου παραθύρου θα "
"επανέλθουν στις προεπιλογές συστήματος. Επαναφέρονται επίσης το hinting και "
"το antialiasing."

msgid "Reset"
msgstr "Επαναφορά"

msgid "Fonts reset to defaults"
msgstr "Οι γραμματοσειρές επαναφέρθηκαν στις προεπιλογές"

msgid "Featured"
msgstr "Επιλεγμένα"

msgid "Installed"
msgstr "Εγκατεστημένα"

msgid "Install extension?"
msgstr "Να εγκατασταθεί η επέκταση;"

msgid "Remove extension?"
msgstr "Να αφαιρεθεί η επέκταση;"

msgid "Open GNOME Extensions"
msgstr "Άνοιγμα GNOME Extensions"

msgid "No extensions installed"
msgstr "Δεν υπάρχουν εγκατεστημένες επεκτάσεις"

msgid "Enabled"
msgstr "Ενεργοποιημένο"

msgid "Disabled"
msgstr "Απενεργοποιημένο"

msgid "system"
msgstr "σύστημα"

msgid "Disable All"
msgstr "Απενεργοποίηση όλων"

msgid "Enable All"
msgstr "Ενεργοποίηση όλων"

msgid "Disable all extensions?"
msgstr "Να απενεργοποιηθούν όλες οι επεκτάσεις;"

msgid "All extensions will be disabled. You can re-enable them later."
msgstr ""
"Όλες οι επεκτάσεις θα απενεργοποιηθούν. Μπορείτε να τις ενεργοποιήσετε ξανά "
"αργότερα."

msgid "All extensions disabled"
msgstr "Όλες οι επεκτάσεις απενεργοποιήθηκαν"

msgid "All extensions enabled"
msgstr "Όλες οι επεκτάσεις ενεργοποιήθηκαν"

msgid "Click a layout to apply"
msgstr "Κάντε κλικ σε μια διάταξη για εφαρμογή"

msgid "Layout status"
msgstr "Κατάσταση διάταξης"

msgid ""
"Marked layouts contain your saved customizations — click to resume them or "
"apply the original."
msgstr "Οι επισημασμένες διατάξεις περιέχουν τις αποθηκευμένες προσαρμογές σας — κάντε κλικ για να τις συνεχίσετε ή να εφαρμόσετε την αρχική."

msgid "Contains your saved customizations"
msgstr "Περιέχει τις αποθηκευμένες προσαρμογές σας"

msgid "Modified"
msgstr "Τροποποιήθηκε"

msgid "This layout is already active"
msgstr "Αυτή η διάταξη είναι ήδη ενεργή"

msgid ""
"You have previously modified this layout. Resume your changes or apply the "
"original system default?"
msgstr ""
"Έχετε προηγουμένως τροποποιήσει αυτή τη διάταξη. Να συνεχίσετε τις αλλαγές "
"σας ή να εφαρμόσετε την αρχική προεπιλογή συστήματος;"

msgid "Apply original"
msgstr "Εφαρμογή αρχικού"

msgid "Resume my changes"
msgstr "Συνέχιση των αλλαγών μου"

msgid ""
"Apply this layout? A backup of your current configuration will be created "
"automatically."
msgstr ""
"Να εφαρμοστεί αυτή η διάταξη; Θα δημιουργηθεί αυτόματα ένα αντίγραφο "
"ασφαλείας της τρέχουσας ρύθμισής σας."

msgid "Apply"
msgstr "Εφαρμογή"

msgid "Applying"
msgstr "Εφαρμογή"

msgid "Snapshot not found"
msgstr "Το στιγμιότυπο δεν βρέθηκε"

msgid "Layout file not found"
msgstr "Το αρχείο διάταξης δεν βρέθηκε"

msgid "applied"
msgstr "εφαρμόστηκε"

msgid "Undo"
msgstr "Αναίρεση"

msgid "Layout restored"
msgstr "Η διάταξη επαναφέρθηκε"

msgid "Previous layout restored"
msgstr "Η προηγούμενη διάταξη επαναφέρθηκε"

msgid "Default Big Gnome layout"
msgstr "Προεπιλεγμένη διάταξη Big Gnome"

msgid "Clean and contemporary desktop"
msgstr "Καθαρή και σύγχρονη επιφάνεια εργασίας"

msgid "Centered dock-taskbar, Windows 11 / Deepin / Pop!_OS style"
msgstr "Κεντραρισμένο dock-γραμμή εργασιών, στυλ Windows 11 / Deepin / Pop!_OS"

msgid "Unity-style layout with left dock and top bar"
msgstr "Διάταξη στυλ Unity με αριστερό dock και πάνω γραμμή"

msgid "Traditional desktop with taskbar and system tray"
msgstr ""
"Παραδοσιακός επιφάνεια εργασίας με γραμμή εργασιών και δίσκο συστήματος"

msgid "Near-vanilla GNOME with minimal distro tweaks"
msgstr "Σχεδόν καθαρό GNOME με ελάχιστες τροποποιήσεις διανομής"
