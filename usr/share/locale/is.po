msgstr "Allar viðbætur virkar"

msgid "Click a layout to apply"
msgstr "Smelltu á uppsetningu til að beita henni"

msgid "Layout status"
msgstr "Staða uppsetningar"

msgid ""
"Marked layouts contain your saved customizations — click to resume them or "
"apply the original."
msgstr "Merktar útlitsskipanir innihalda vistuð aðlögun — smelltu til að halda áfram eða nota upprunalegt."

msgid "Contains your saved customizations"
msgstr "Inniheldur vistaðar sérsniðanir þínar"

msgid "Modified"
msgstr "Breytt"

msgid "This layout is already active"
msgstr "Þessi uppsetning er þegar virk"

msgid ""
"You have previously modified this layout. Resume your changes or apply the "
"original system default?"
msgstr ""
"Þú hefur áður breytt þessari uppsetningu. Halda áfram með breytingarnar eða "
"beita upprunalegu kerfisstilltunni?"

msgid "Apply original"
msgstr "Beita upprunalegu"

msgid "Resume my changes"
msgstr "Halda áfram með breytingar mínar"

msgid ""
"Apply this layout? A backup of your current configuration will be created "
