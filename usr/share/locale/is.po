msgstr "Hvernig á að setja upp"

msgid ""
"Place .ttf/.otf files in ~/.local/share/fonts/ then run 'fc-cache -f -v' and "
"refresh this list."
msgstr ""
"Settu .ttf/.otf skrár í ~/.local/share/fonts/ og keyrðu svo 'fc-cache -f -v' "
"og endurnýjaðu þennan lista."

msgid "Reset to system defaults"
msgstr "Endurstilltu í kerfisstillingar"

msgid "Reset all font settings?"
msgstr "Endurstilltu allar leturstillingar?"

msgid ""
"Interface, document, monospace and window-title fonts will return to system "
"defaults. Hinting and antialiasing reset too."
msgstr ""
"Letur fyrir viðmót, skjöl, monospace og gluggatitla verður endurstillt í "
"kerfisstillingar. Hinting og antialiasing verða einnig endurstillt."

