msgstr "Резервну копію створено"

msgid "Backup failed"
msgstr "Не вдалося створити резервну копію"

msgid "Restore this backup?"
msgstr "Відновити цю резервну копію?"

#, python-brace-format
msgid ""
"All current dconf settings will be overwritten with the snapshot from {ts}."
msgstr "Позначені макети містять збережені налаштування — натисніть, щоб відновити їх або застосувати оригінал."msgid "Cancel"
msgstr "Скасувати"

msgid "Restore"
msgstr "Відновити"

msgid "Backup restored"
msgstr "Резервну копію відновлено"

msgid "Restore failed"
msgstr "Не вдалося відновити"

msgid "Delete this backup?"
msgstr "Видалити цю резервну копію?"

msgid "Delete"
msgstr "Видалити"

msgid "Backup deleted"
msgstr "Резервну копію видалено"

msgid "Delete failed"
msgstr "Не вдалося видалити"

