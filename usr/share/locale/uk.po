msgid "Backups"
msgstr "Резервні копії"

msgid "Create backup now"
msgstr "Створити резервну копію зараз"

msgid "Snapshot current dconf settings"
msgstr "Зробити знімок поточних налаштувань dconf"

msgid "No backups yet"
msgstr "Резервних копій ще немає"

msgid "A backup is created automatically every time you apply a layout."
msgstr ""
"Резервна копія створюється автоматично щоразу, коли ви застосовуєте макет."

msgid "Latest"
msgstr "Остання"

msgid "Restore this backup"
msgstr "Відновити цю резервну копію"

