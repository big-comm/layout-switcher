msgid "System fonts"
msgstr "Системні шрифти"

msgid "Fonts used by the GNOME interface"
msgstr "Шрифти, що використовуються інтерфейсом GNOME"

msgid "Interface"
msgstr "Інтерфейс"

msgid "Document"
msgstr "Документ"

msgid "Monospace"
msgstr "Моноширинний"

msgid "Window titles (legacy)"
msgstr "Заголовки вікон (спадщина)"

msgid "(not set)"
msgstr "(не встановлено)"

msgid "Choose…"
msgstr "Вибрати…"

