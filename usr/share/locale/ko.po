msgid "Backups"
msgstr "백업"

msgid "Create backup now"
msgstr "지금 백업 생성"

msgid "Snapshot current dconf settings"
msgstr "현재 dconf 설정 스냅샷"

msgid "No backups yet"
msgstr "아직 백업이 없습니다"

msgid "A backup is created automatically every time you apply a layout."
msgstr "레이아웃을 적용할 때마다 백업이 자동으로 생성됩니다."

msgid "Latest"
msgstr "최신"

msgid "Restore this backup"
msgstr "이 백업 복원"

msgid "Delete this backup"
msgstr "이 백업 삭제"

msgid "Backup created"
msgstr "백업 생성 완료"

msgid "Backup failed"
msgstr "백업 실패"

msgid "Restore this backup?"
msgstr "이 백업을 복원하시겠습니까?"

#, python-brace-format
msgid ""
"All current dconf settings will be overwritten with the snapshot from {ts}."
msgstr "표시된 레이아웃에는 저장된 사용자 지정이 포함되어 있습니다 — 클릭하여 재개하거나 원본을 적용하세요."msgid "Cancel"
msgstr "취소"

msgid "Restore"
msgstr "복원"

msgid "Backup restored"
msgstr "백업 복원 완료"

msgid "Restore failed"
msgstr "복원 실패"

msgid "Delete this backup?"
msgstr "이 백업을 삭제하시겠습니까?"

msgid "Delete"
msgstr "삭제"

msgid "Backup deleted"
msgstr "백업 삭제됨"

msgid "Delete failed"
msgstr "삭제 실패"

msgid "Layout Switcher"
msgstr "Layout Switcher"

msgid "Show Sidebar"
msgstr "사이드바 표시"

msgid "Layouts"
msgstr "레이아웃"

msgid "Menu"
msgstr "메뉴"

msgid "Main menu"
msgstr "메인 메뉴"

msgid "Backups…"
msgstr "백업…"

msgid "About"
msgstr "정보"

msgid "Welcome! Choose a desktop layout below to get started."
msgstr "환영합니다! 시작하려면 아래에서 데스크탑 레이아웃을 선택하세요."

msgid "Got it"
msgstr "알겠습니다"

msgid "Fonts"
msgstr "글꼴"

msgid "Themes"
msgstr "테마"

msgid "Effects"
msgstr "효과"

msgid "Extensions"
msgstr "확장 기능"

msgid "Community Layout Switcher"
msgstr "커뮤니티 Layout Switcher"

msgid "Layouts, effects and themes for your GNOME desktop."
msgstr "GNOME 데스크탑을 위한 레이아웃, 효과 및 테마입니다."

msgid "Filter themes…"
msgstr "테마 필터…"

msgid "Icons"
msgstr "아이콘"

msgid "No themes found"
msgstr "테마를 찾을 수 없습니다"

msgid "Install themes to ~/.themes or /usr/share/themes"
msgstr "테마를 ~/.themes 또는 /usr/share/themes에 설치하세요"

msgid "themes available"
msgstr "사용 가능한 테마"

msgid "theme"
msgstr "테마"

msgid "Active"
msgstr "활성"

msgid "Error"
msgstr "오류"

msgid "User Themes required"
msgstr "사용자 테마 필요"

msgid "Install and enable the User Themes extension to apply shell themes."
msgstr "셸 테마를 적용하려면 User Themes 확장 기능을 설치하고 활성화하세요."

msgid "Open Extensions Page"
msgstr "확장 기능 페이지 열기"

msgid "Visual effects for your GNOME desktop"
msgstr "GNOME 데스크탑을 위한 시각 효과"

msgid "System extension"
msgstr "시스템 확장 기능"

msgid "enabled"
msgstr "활성화됨"

msgid "disabled"
msgstr "비활성화됨"

msgid "Not installed"
msgstr "설치되지 않음"

#, python-brace-format
msgid "by {author}"
msgstr "작성자 {author}"

msgid "On"
msgstr "켬"

msgid "Off"
msgstr "끔"

msgid "Toggle"
msgstr "전환"

msgid "Remove"
msgstr "제거"

msgid "Settings"
msgstr "설정"

msgid "Install"
msgstr "설치"

msgid "View on GNOME Extensions"
msgstr "GNOME Extensions에서 보기"

msgid "Install effect?"
msgstr "효과를 설치하시겠습니까?"

msgid "Will try to install automatically."
msgstr "자동으로 설치를 시도합니다."

msgid "Installing…"
msgstr "설치 중…"

msgid "installed"
msgstr "설치 완료"

msgid "Install failed"
msgstr "설치 실패"

msgid "System extension — cannot remove"
msgstr "시스템 확장 기능 — 제거할 수 없습니다"

msgid "Remove effect?"
msgstr "효과를 제거하시겠습니까?"

msgid "This cannot be undone."
msgstr "이 작업은 되돌릴 수 없습니다."

msgid "removed"
msgstr "제거 완료"

msgid "Remove failed"
msgstr "제거 실패"

msgid "System fonts"
msgstr "시스템 글꼴"

msgid "Fonts used by the GNOME interface"
msgstr "GNOME 인터페이스에서 사용하는 글꼴"

msgid "Interface"
msgstr "인터페이스"

msgid "Document"
msgstr "문서"

msgid "Monospace"
msgstr "고정폭 글꼴"

msgid "Window titles (legacy)"
msgstr "창 제목 (레거시)"

msgid "(not set)"
msgstr "(설정 안 됨)"

msgid "Choose…"
msgstr "선택…"

msgid "Choose font"
msgstr "글꼴 선택"

msgid "Font updated"
msgstr "글꼴이 업데이트되었습니다"

msgid "Update failed"
msgstr "업데이트 실패"

msgid "Appearance"
msgstr "모양"

msgid "How fonts are rendered on screen"
msgstr "화면에 글꼴이 렌더링되는 방식"

msgid "Hinting"
msgstr "힌팅"

msgid "None"
msgstr "없음"

msgid "Slight"
msgstr "약간"

msgid "Medium"
msgstr "중간"

msgid "Full"
msgstr "전체"

msgid "Antialiasing"
msgstr "안티앨리어싱"

msgid "Grayscale"
msgstr "그레이스케일"

msgid "Subpixel (RGBA)"
msgstr "서브픽셀 (RGBA)"

msgid "Installed fonts"
msgstr "설치된 글꼴"

msgid "Browse font families installed on your system"
msgstr "시스템에 설치된 글꼴 패밀리 탐색"

msgid "Search fonts…"
msgstr "글꼴 검색…"

msgid "Refresh font list"
msgstr "글꼴 목록 새로고침"

msgid "Loading fonts…"
msgstr "글꼴 로딩 중…"

msgid "No fonts match your search"
msgstr "검색 결과와 일치하는 글꼴이 없습니다"

msgid "(refine search to see more)"
msgstr "(검색을 좁혀 더 많은 결과 보기)"

msgid "fonts"
msgstr "글꼴"

msgid "The quick brown fox jumps over the lazy dog 0123"
msgstr "키스의 고유조건은 입술끼리 만나야 하는 것 0123"

msgid "Install more fonts"
msgstr "글꼴 더 설치하기"

msgid "Browse Google Fonts"
msgstr "Google Fonts 탐색"

msgid "Opens fonts.google.com in your browser"
msgstr "브라우저에서 fonts.google.com 열기"

msgid "How to install"
msgstr "설치 방법"

msgid ""
"Place .ttf/.otf files in ~/.local/share/fonts/ then run 'fc-cache -f -v' and "
"refresh this list."
msgstr ""
".ttf/.otf 파일을 ~/.local/share/fonts/에 넣고 'fc-cache -f -v'를 실행한 후 "
"이 목록을 새로고침하세요."

msgid "Reset to system defaults"
msgstr "시스템 기본값으로 재설정"

msgid "Reset all font settings?"
msgstr "모든 글꼴 설정을 재설정하시겠습니까?"

msgid ""
"Interface, document, monospace and window-title fonts will return to system "
"defaults. Hinting and antialiasing reset too."
msgstr ""
"인터페이스, 문서, 고정폭 및 창 제목 글꼴이 시스템 기본값으로 돌아갑니다. 힌팅"
"과 안티앨리어싱도 재설정됩니다."

msgid "Reset"
msgstr "재설정"

msgid "Fonts reset to defaults"
msgstr "글꼴이 기본값으로 재설정되었습니다"

msgid "Featured"
msgstr "추천"

msgid "Installed"
msgstr "설치됨"

msgid "Install extension?"
msgstr "확장 기능을 설치하시겠습니까?"

msgid "Remove extension?"
msgstr "확장 기능을 제거하시겠습니까?"

msgid "Open GNOME Extensions"
msgstr "GNOME 확장 기능 열기"

msgid "No extensions installed"
msgstr "설치된 확장 기능이 없습니다"

msgid "Enabled"
msgstr "활성화됨"

msgid "Disabled"
msgstr "비활성화됨"

msgid "system"
msgstr "시스템"

msgid "Disable All"
msgstr "모두 비활성화"

msgid "Enable All"
msgstr "모두 활성화"

msgid "Disable all extensions?"
msgstr "모든 확장 기능을 비활성화하시겠습니까?"

msgid "All extensions will be disabled. You can re-enable them later."
msgstr "모든 확장 기능이 비활성화됩니다. 나중에 다시 활성화할 수 있습니다."

msgid "All extensions disabled"
msgstr "모든 확장 기능이 비활성화됨"

msgid "All extensions enabled"
msgstr "모든 확장 기능이 활성화됨"

msgid "Click a layout to apply"
msgstr "적용할 레이아웃을 클릭하세요"

msgid "Layout status"
msgstr "레이아웃 상태"

msgid ""
"Marked layouts contain your saved customizations — click to resume them or "
"apply the original."
msgstr "표시된 레이아웃에는 저장된 사용자 지정이 포함되어 있습니다 — 클릭하여 재개하거나 원본을 적용하세요."

msgid "Contains your saved customizations"
msgstr "저장된 사용자 설정을 포함합니다"

msgid "Modified"
msgstr "수정됨"

msgid "This layout is already active"
msgstr "이 레이아웃은 이미 활성화되어 있습니다"

msgid ""
"You have previously modified this layout. Resume your changes or apply the "
"original system default?"
msgstr ""
"이전에 이 레이아웃을 수정했습니다. 변경 사항을 계속 적용하시겠습니까, 아니면 "
"원래 시스템 기본값을 적용하시겠습니까?"

msgid "Apply original"
msgstr "원래대로 적용"

msgid "Resume my changes"
msgstr "내 변경 사항 계속 적용"

msgid ""
"Apply this layout? A backup of your current configuration will be created "
"automatically."
msgstr ""
"이 레이아웃을 적용하시겠습니까? 현재 구성의 백업이 자동으로 생성됩니다."

msgid "Apply"
msgstr "적용"

msgid "Applying"
msgstr "적용 중"

msgid "Snapshot not found"
msgstr "스냅샷을 찾을 수 없습니다"

msgid "Layout file not found"
msgstr "레이아웃 파일을 찾을 수 없습니다"

msgid "applied"
msgstr "적용됨"

msgid "Undo"
msgstr "실행 취소"

msgid "Layout restored"
msgstr "레이아웃 복원됨"

msgid "Previous layout restored"
msgstr "이전 레이아웃 복원됨"

msgid "Default Big Gnome layout"
msgstr "기본 Big Gnome 레이아웃"

msgid "Clean and contemporary desktop"
msgstr "깔끔하고 현대적인 데스크탑"

msgid "Centered dock-taskbar, Windows 11 / Deepin / Pop!_OS style"
msgstr "중앙 정렬 도크-작업 표시줄, Windows 11 / Deepin / Pop!_OS 스타일"

msgid "Unity-style layout with left dock and top bar"
msgstr "왼쪽 도크와 상단 바가 있는 Unity 스타일 레이아웃"

msgid "Traditional desktop with taskbar and system tray"
msgstr "작업 표시줄과 시스템 트레이가 있는 전통적인 데스크탑"

msgid "Near-vanilla GNOME with minimal distro tweaks"
msgstr "최소한의 배포판 수정이 적용된 거의 기본 GNOME"
