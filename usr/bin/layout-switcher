#!/usr/bin/env bash
# layout-switcher — Launcher for Community Layout Switcher

set -euo pipefail

APP_DIRS=(
    "/usr/share/layout-switcher"
    "/usr/local/share/layout-switcher"
)

APP_DIR=""
for dir in "${APP_DIRS[@]}"; do
    if [[ -f "${dir}/main.py" ]]; then
        APP_DIR="${dir}"
        break
    fi
done

# Development fallback: relative to this script
if [[ -z "${APP_DIR}" ]]; then
    SCRIPT_DIR="$(dirname "$(readlink -f "$0")")"
    APP_DIR="${SCRIPT_DIR}/../share/layout-switcher"
fi

if [[ ! -f "${APP_DIR}/main.py" ]]; then
    echo "Error: layout-switcher not found." >&2
    exit 1
fi

if [[ -z "${GSK_RENDERER:-}" ]]; then
    if compgen -G /var/lib/pacman/local/mesa-amber-* >/dev/null || systemd-detect-virt -q; then
        export GSK_RENDERER="cairo"
    fi
fi

exec python3 "${APP_DIR}/main.py" "$@"
