pkgname=layout-switcher
pkgdesc="Manage GNOME layouts, extensions and themes"
depends=(
    # Runtime
    'python'
    'python-gobject'
    'gtk4'
    'libadwaita'
    'gnome-shell'
    # GNOME Shell extensions used by the bundled layouts
    'gnome-shell-big-shot'
    'gnome-shell-extension-appindicator'
    'gnome-shell-extension-arc-menu'
    'gnome-shell-extension-blur-my-shell'
    'gnome-shell-extension-copyous'
    'gnome-shell-extension-dash-to-dock'
    'gnome-shell-extension-dash-to-panel'
    'gnome-shell-extension-gsconnect'
    'gnome-shell-extension-gtk4-desktop-icons-ng'
    'gnome-shell-extension-kiwi-kemma'
    'gnome-shell-extension-legacy-theme-auto-switcher'
    'gnome-shell-extensions'
)
#makedepends=('')
#optdepends=('')
#conflicts=('')
#provides=('')
#replaces=('')
pkgver=$(date +%y.%m.%d)
pkgrel=$(date +%H%M)
arch=('any')
license=('MIT')
url="https://github.com/big-comm/${pkgname}"
source=("git+${url}.git")
md5sums=('SKIP')

# Automatically detect and use the correct install file
if [ -e "${pkgname}.install" ]; then
    install=${pkgname}.install
elif [ -e "pkgbuild.install" ]; then
    install=pkgbuild.install
fi

prepare() {
    cd "${srcdir}/${pkgname}"
    # Add any preparation steps here, if needed
    # For example: patch -p1 < "${srcdir}/patch-file.patch"
}

build() {
    cd "${srcdir}/${pkgname}"
    # Add build steps here, if needed
    # For example: make
}

check() {
    cd "${srcdir}/${pkgname}"
    # Add check/test steps here, if needed
    # For example: make check
}

package() {
    cd "${srcdir}/${pkgname}"

    # Determine the correct source directory.
    # Use a local var — sobrescrever ${srcdir} (gerenciado pelo makepkg) quebra
    # builds incrementais e qualquer convenção de empacotamento.
    local pkgsrc
    if [ -d "${pkgname}" ]; then
        pkgsrc="${srcdir}/${pkgname}/${pkgname}"
    else
        pkgsrc="${srcdir}/${pkgname}"
    fi

    # Install files
    local dirs=("usr" "etc" "opt")
    for dir in "${dirs[@]}"; do
        if [ -d "${pkgsrc}/${dir}" ]; then
            cp -a "${pkgsrc}/${dir}" "${pkgdir}/"
        fi
    done

    # Install license file if present
    if [ -f "${pkgsrc}/LICENSE" ]; then
        install -Dm644 "${pkgsrc}/LICENSE" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
    fi

    # Install documentation if present
    if [ -f "${pkgsrc}/README.md" ]; then
        install -Dm644 "${pkgsrc}/README.md" "${pkgdir}/usr/share/doc/${pkgname}/README.md"
    fi
}
